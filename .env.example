################################################################################
# ENVIRONMENT SETUP - Video Loan System
# README: Only fill in the REQUIRED (✅) fields to get started
# OPTIONAL (⭕) fields can be added later when needed
################################################################################

# ============================================================================
# 🗄️  DATABASE CONFIGURATION - REQUIRED ✅
# ============================================================================
# PostgreSQL via NeonDB (Free tier: https://neon.tech)
# Get CONNECTION_STRING from Neon dashboard and paste here
DATABASE_URL=postgresql://user:password@ep-xxxxxx.us-east-2.neon.tech/neondb

# Redis (Use Docker: docker run -d -p 6379:6379 redis:7)
REDIS_URL=redis://localhost:6379

# MongoDB - OPTIONAL ⭕ (For audit logs - use local Docker or MongoDB Atlas)
# If using Docker: docker run -d -p 27017:27017 mongo:7
# If using Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/video_loan_system

# ============================================================================
# 🔐 JWT & AUTHENTICATION - REQUIRED ✅
# ============================================================================
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_random_string_at_least_32_characters_long
JWT_EXPIRY=24h
OTP_EXPIRY=5m

# ============================================================================
# 🤖 AI/ML SERVICES - Choose ONE ✅ (Groq recommended - highest rate limits)
# ============================================================================
# Choose your LLM provider based on rate limits and cost:
# 
# 🏆 GROQ (30 req/min, fastest - RECOMMENDED FOR DEVELOPMENT)
# Get key from: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-key-here

# 🏠 LOCAL OLLAMA (Unlimited, zero rate limits - BEST FOR LOCAL DEV)
# Install from: https://ollama.ai
# Run: ollama run mistral
# Then uncomment these:
# LLM_PROVIDER=ollama
# LOCAL_LLM_URL=http://localhost:11434

# 🔵 GOOGLE GEMINI (60 req/min, good free tier)
# Get key from: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key-here

# ⚪ OpenAI (3 req/min, higher cost)
# Get key from: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here

# 🐜 Anthropic Claude (1 req/min, most restrictive)
# Get key from: https://console.anthropic.com
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================================
# 🎤 SPEECH-TO-TEXT (STT) - REQUIRED ✅
# ============================================================================
# Deepgram (Recommended - $200 free credits per month)
# Get key from: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

# ============================================================================
# �️  VISION SERVICE - REQUIRED ✅ (Age & Liveness Detection)
# ============================================================================
# Using MediaPipe (FREE, local, no API keys needed!) ⭐
# VISION_PROVIDER=mediapipe (default - requires: mediapipe, opencv-python)
#
# Alternative: Use cloud providers (AWS Rekognition, Google Vision, etc.)
# Note: AWS/Google require paid API keys
VISION_PROVIDER=mediapipe
FACE_DETECTION_CONFIDENCE=0.5
AGE_ESTIMATION_ACCURACY=high

# ============================================================================
# �📞 SMS/OTP SERVICES - OPTIONAL ⭕ (For production only)
# ============================================================================
# Twilio (Optional - for SMS/OTP)
# Get from: https://www.twilio.com
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# MSG91 (Alternative SMS provider)
# MSG91_AUTH_KEY=your_msg91_auth_key

# ============================================================================
# ☁️  AWS CONFIGURATION - OPTIONAL ⭕ (For S3 video storage only)
# ============================================================================
# Vision service uses MediaPipe (free, local) - NO AWS needed for age/liveness
# Only add AWS keys if you want to store videos in S3 for production
# Get credentials from: https://console.aws.amazon.com/iam
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_S3_BUCKET=video-loan-recordings

# ============================================================================
# 🌐 SERVICE PORTS - REQUIRED ✅
# ============================================================================
API_GATEWAY_PORT=3000
SESSION_SERVICE_PORT=3001
MEDIA_SERVICE_PORT=3002
STT_SERVICE_PORT=3003
KYC_SERVICE_PORT=3004
RISK_SERVICE_PORT=3005
VISION_SERVICE_PORT=3006
LLM_SERVICE_PORT=3007
OFFER_SERVICE_PORT=3008
AUDIT_SERVICE_PORT=3009

# ============================================================================
# 🔧 APPLICATION SETTINGS - REQUIRED ✅
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================================================
# 📹 WebRTC CONFIGURATION - OPTIONAL ⭕ (For production deployment)
# ============================================================================
# Google STUN servers (free, no configuration needed for local development)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server (Only needed if behind NAT - use Twilio or self-hosted)
# TURN_SERVER_URL=turn:your.turn.server.com:3478
# TURN_USERNAME=your_turn_username
# TURN_PASSWORD=your_turn_password

# ============================================================================
# 🎯 ML MODEL CONFIGURATION - OPTIONAL ⭕
# ============================================================================
LIVENESS_CONFIDENCE_THRESHOLD=0.85
AGE_ESTIMATION_CONFIDENCE_THRESHOLD=0.80

# ============================================================================
# 💰 LOAN POLICY CONFIGURATION - REQUIRED ✅
# ============================================================================
MIN_LOAN_AMOUNT=10000
MAX_LOAN_AMOUNT=500000
MIN_AGE=18
MAX_AGE=65
