# ===================================
# Database Configuration
# ===================================
# PostgreSQL (DO NOT use 'password' in production!)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=video_loan_db
DATABASE_URL=postgresql://postgres:change_me_in_production@localhost:5432/video_loan_db?sslmode=require

# MongoDB (DO NOT use 'password' in production!)
MONGODB_USER=admin
MONGODB_PASSWORD=change_me_in_production
MONGODB_URI=mongodb://admin:change_me_in_production@localhost:27017/video_loan_system

# Redis
REDIS_URL=redis://localhost:6379

# ===================================
# Authentication & Security
# ===================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters recommended
JWT_SECRET=change_me_generate_random_32_char_string
JWT_EXPIRY=24h
OTP_EXPIRY=5m

# ===================================
# AI / ML API Keys (Required for real-world usage)
# ===================================
# Get your free API key from: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_change_me_with_your_actual_key

# Speech-to-Text (optional - browser API fallback available)
# Get your free API key from: https://console.deepgram.com
DEEPGRAM_API_KEY=change_me_with_your_deepgram_key

# Alternative LLM Providers (choose one)
# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-change_me_with_your_key

# Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=change_me_with_your_gemini_key

# Anthropic Claude: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-change_me_with_your_key

# Local LLM (Ollama): http://localhost:11434
# LOCAL_LLM_URL=http://localhost:11434

# ===================================
# Service Ports
# ===================================
API_GATEWAY_PORT=3000
SESSION_SERVICE_PORT=3001
MEDIA_SERVICE_PORT=3002
STT_SERVICE_PORT=3003
KYC_SERVICE_PORT=3004
RISK_SERVICE_PORT=3005
VISION_SERVICE_PORT=3006
LLM_SERVICE_PORT=3007
OFFER_SERVICE_PORT=3008
AUDIT_SERVICE_PORT=3009

# ===================================
# Application Config
# ===================================
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ===================================
# WebRTC
# ===================================
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ===================================
# Vision Service (MediaPipe - no API keys)
# ===================================
VISION_PROVIDER=mediapipe
FACE_DETECTION_CONFIDENCE=0.5
LIVENESS_CONFIDENCE_THRESHOLD=0.85
AGE_ESTIMATION_CONFIDENCE_THRESHOLD=0.80

# ===================================
# Loan Policy
# ===================================
MIN_LOAN_AMOUNT=10000
MAX_LOAN_AMOUNT=500000
MIN_AGE=18
MAX_AGE=65
