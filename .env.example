# ===================================
# Database
# ===================================
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/video_loan_system

# ===================================
# Authentication
# ===================================
JWT_SECRET=your-jwt-secret-min-32-chars-here
JWT_EXPIRY=24h
OTP_EXPIRY=5m

# ===================================
# AI / ML API Keys (REQUIRED for real-world usage)
# ===================================
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key

# Optional LLM providers (if not using Groq)
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# GEMINI_API_KEY=your-gemini-key
# LOCAL_LLM_URL=http://localhost:11434

# ===================================
# Service Ports
# ===================================
API_GATEWAY_PORT=3000
SESSION_SERVICE_PORT=3001
MEDIA_SERVICE_PORT=3002
STT_SERVICE_PORT=3003
KYC_SERVICE_PORT=3004
RISK_SERVICE_PORT=3005
VISION_SERVICE_PORT=3006
LLM_SERVICE_PORT=3007
OFFER_SERVICE_PORT=3008
AUDIT_SERVICE_PORT=3009

# ===================================
# Application Config
# ===================================
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ===================================
# WebRTC
# ===================================
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ===================================
# Vision Service (MediaPipe - no API keys)
# ===================================
VISION_PROVIDER=mediapipe
FACE_DETECTION_CONFIDENCE=0.5
LIVENESS_CONFIDENCE_THRESHOLD=0.85
AGE_ESTIMATION_CONFIDENCE_THRESHOLD=0.80

# ===================================
# Loan Policy
# ===================================
MIN_LOAN_AMOUNT=10000
MAX_LOAN_AMOUNT=500000
MIN_AGE=18
MAX_AGE=65
