// Prisma Schema for Video Loan System
// PostgreSQL via NeonDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  phoneNumber         String    @unique
  firstName           String
  lastName            String    @default("")
  role                String    @default("customer")

  // KYC
  kycStatus           String    @default("pending")
  kycVerifiedAt       DateTime?

  // Financial
  employmentStatus    String?
  monthlyIncome       Float?
  loanPurpose         String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions            VideoSession[]
  offers              LoanOffer[]
  consents            ConsentRecord[]

  @@map("users")
}

model VideoSession {
  id                  String    @id
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  status              String    @default("active")
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  duration            Int?

  // Location
  latitude            Float?
  longitude           Float?

  // Device
  userAgent           String?
  ipAddress           String?
  platform            String?

  // Pipeline results (stored as JSON)
  transcript          String?
  sttResult           Json?
  llmResult           Json?
  riskResult          Json?
  pipelineResult      Json?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  offers              LoanOffer[]
  consents            ConsentRecord[]

  @@map("video_sessions")
}

model LoanOffer {
  id                  String    @id
  sessionId           String
  session             VideoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  loanAmount          Float
  tenureMonths        Int
  interestRate        Float
  emi                 Float
  totalPayable        Float     @default(0)
  totalInterest       Float     @default(0)
  eligibilityStatus   String    @default("pending")
  conditions          String[]  @default([])
  loanPurpose         String?

  generatedAt         DateTime  @default(now())
  expiresAt           DateTime
  accepted            Boolean   @default(false)
  acceptedAt          DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("loan_offers")
}

model ConsentRecord {
  id                  String    @id @default(cuid())
  sessionId           String
  session             VideoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  consentType         String
  verballyAgreed      Boolean   @default(false)

  createdAt           DateTime  @default(now())

  @@map("consent_records")
}
